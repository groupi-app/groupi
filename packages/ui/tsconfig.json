{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@groupi/schema": ["../../packages/schema/src"],
      "@groupi/schema/*": ["../../packages/schema/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
