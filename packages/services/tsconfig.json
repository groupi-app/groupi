{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "module": "ESNext",
    "downlevelIteration": true,
    "paths": {
      "@/*": ["./src/*"],
      "@groupi/schema": ["../schema/src"],
      "@groupi/schema/*": ["../schema/src/*"],
      "@groupi/ui": ["../ui/src"],
      "@groupi/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
