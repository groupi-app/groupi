{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@groupi/schema": ["../schema/src"],
      "@groupi/schema/*": ["../schema/src/*"],
      "@groupi/services": ["../services/src"],
      "@groupi/services/*": ["../services/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
