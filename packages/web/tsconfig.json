{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/convex/*": ["../../convex/*"],
      "@/*": ["./*"],
      "@groupi/shared": ["../../packages/shared/src"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "env.mjs"
  ],
  "exclude": [
    "node_modules",
    "../../convex/tests/**/*",
    "../../convex/**/*.test.ts",
    "../../convex/**/*.test.tsx",
    "**/test-helpers.tsx",
    "e2e/**/*",
    "stories/**/*",
    ".storybook/**/*"
  ]
}
