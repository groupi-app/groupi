# Core Application
# REQUIRED: Base URL for the application (used for invite links, emails, etc.)
# Set to http://localhost:3000 for local development
# Set to https://groupi.gg (or your domain) for production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Convex Configuration
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3000
CONVEX_DEPLOY_KEY=your-convex-deploy-key

# Better Auth
BETTER_AUTH_SECRET=your-very-long-secret-here-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Resend (Email)
RESEND_API_KEY=re_your-resend-api-key

# Pusher (Real-time features - will be replaced by Convex subscriptions)
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_SECRET=your-pusher-app-secret
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-app-key
NEXT_PUBLIC_PUSHER_APP_CLUSTER=your-pusher-cluster

# Pusher Beams (Push notifications)
PUSHER_BEAMS_SECRET_KEY=your-pusher-beams-secret
NEXT_PUBLIC_PUSHER_BEAMS_INSTANCE_ID=your-pusher-beams-instance-id

# Google APIs
GOOGLE_API_KEY=your-google-api-key
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-api-key

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Optional: UploadThing
UPLOADTHING_TOKEN=your-uploadthing-token

# Optional: Debugging
DEBUG=false

# Optional: Grafana Cloud Loki (Logging)
LOKI_ENABLED=false
LOKI_URL=https://your-loki-instance.grafana.net
LOKI_INSTANCE_ID=your-instance-id
LOKI_TOKEN=your-loki-token

# Legacy Supabase (deprecated - will be removed after Convex migration)
# DATABASE_URL=your-supabase-database-url
# DIRECT_URL=your-supabase-direct-url
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key