# =====================================================
# Groupi Environment Variables (Example)
# Copy to .env.local and fill in your actual values
# =====================================================

# =====================================================
# Core Application Settings
# =====================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DEBUG=true

# =====================================================
# Convex Backend (Primary Database & Real-time)
# =====================================================
# Get these from `pnpx convex dev` or Convex dashboard
CONVEX_DEPLOYMENT=dev:your-convex-deployment # team: yourteam, project: yourproject
CONVEX_URL=https://your-convex-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3000

# =====================================================
# Better Auth (Authentication System)
# =====================================================
# Generate a secure random string for the secret
BETTER_AUTH_SECRET=your-super-secret-auth-key-here-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# =====================================================
# OAuth Providers
# =====================================================
# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Discord OAuth (for social login)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# =====================================================
# Email Service (Resend)
# =====================================================
RESEND_API_KEY=re_your-resend-api-key
# For development, use onboarding@resend.dev (default verified domain)
# For production, replace with your verified domain
RESEND_FROM_EMAIL=onboarding@resend.dev

# =====================================================
# File Upload Service (UploadThing)
# =====================================================
UPLOADTHING_TOKEN=your-uploadthing-token

# =====================================================
# Development Tools
# =====================================================
# Cache logging (set to "false" to disable)
NEXT_PUBLIC_LOG_CACHE=true

# =====================================================
# AI Services (Smart Date Input)
# =====================================================
# Groq API for cost-effective LLM inference
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key

# =====================================================
# Monitoring & Analytics
# =====================================================
# Sentry Error Tracking
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Grafana Cloud Loki Logging (set LOKI_ENABLED=true to enable)
LOKI_ENABLED=false
LOKI_URL=https://logs-prod-xxx.grafana.net/loki/api/v1/push
LOKI_INSTANCE_ID=your-instance-id
LOKI_TOKEN=your-loki-token
LOKI_SERVICE=web

# =====================================================
# Setup Instructions
# =====================================================
# 1. Copy this file to .env.local
# 2. Run: pnpx convex dev (get CONVEX_* variables)
# 3. Generate BETTER_AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 4. Configure OAuth providers (optional)
# 5. Set up external services (optional)
# 6. Run: pnpm dev
#
# For production:
# 1. Update all localhost URLs to production values
# 2. Run: pnpx convex deploy
# 3. Set production OAuth redirect URIs
# =====================================================