# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Clerk Authentication (Legacy - may be deprecated)
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SIGNING_SECRET=whsec_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_X_FORCE_REDIRECT_URL=/

# Pusher Configuration
PUSHER_APP_ID=
PUSHER_APP_SECRET=
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_CLUSTER=us2
NEXT_PUBLIC_PUSHER_BEAMS_INSTANCE_ID=
PUSHER_BEAMS_SECRET_KEY=

# Google APIs
GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Ngrok Configuration (for local development tunneling)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Resend Email Configuration
RESEND_API_KEY=re_
# For development, use onboarding@resend.dev (default verified domain)
# For production, replace with your verified domain
RESEND_FROM_EMAIL=onboarding@resend.dev

# Application Configuration
# Base URL for the application (used in email templates)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DEBUG=true

# Better Auth Configuration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# UploadThing Configuration
UPLOADTHING_TOKEN=

# Cache Logging
# Works in both dev and production. Set to "false" to disable
NEXT_PUBLIC_LOG_CACHE=true

# Supabase Configuration
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALG=HS256
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Service Role Key (local dev only - bypasses JWT verification)
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# Grafana Cloud Loki Configuration
# Enable Loki logging by setting LOKI_ENABLED=true
LOKI_ENABLED=false
LOKI_URL=https://logs-prod-036.grafana.net/loki/api/v1/push
LOKI_INSTANCE_ID=
LOKI_TOKEN=
# Optional: Set service name (defaults to 'services' for services package, 'web' for web app)
LOKI_SERVICE=web

# Sentry Configuration
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
