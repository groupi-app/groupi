// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Person {
  id                    String          @id
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  memberships           Membership[]
  posts                 Post[]
  replies               Reply[]
  firstName             String?
  lastName              String?
  username              String          @unique
  imageUrl              String
  notifications         Notification[]  @relation("PersonNotifications")
  authoredNotifications Notification[]  @relation("AuthorNotifications")
  settings              PersonSettings?
}

// New model to hold all user settings
model PersonSettings {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  person              Person               @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId            String               @unique // Ensures one-to-one relationship
  notificationMethods NotificationMethod[] // Moved from Person model
  // Future settings can be added here
}

model Event {
  id                 String              @id @default(cuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  title              String
  description        String              @default("")
  location           String              @default("")
  chosenDateTime     DateTime?
  invites            Invite[]
  potentialDateTimes PotentialDateTime[]
  posts              Post[]
  memberships        Membership[]
  notifications      Notification[]
}

model Membership {
  id             String         @id @default(cuid())
  person         Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId       String
  eventId        String
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  role           Role           @default(ATTENDEE)
  rsvpStatus     Status         @default(PENDING)
  availabilities Availability[]
  invites        Invite[]
}

model PotentialDateTime {
  id             String         @id @default(cuid())
  eventId        String
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dateTime       DateTime       @default(now())
  availabilities Availability[]
}

model Availability {
  membership          Membership        @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  membershipId        String
  potentialDateTime   PotentialDateTime @relation(fields: [potentialDateTimeId], references: [id], onDelete: Cascade)
  potentialDateTimeId String

  status Status

  @@id(name: "id", [membershipId, potentialDateTimeId])
}

model Post {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  editedAt      DateTime       @default(now())
  author        Person         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  replies       Reply[]
  title         String
  content       String
  notifications Notification[]
}

model Reply {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    Person   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  text      String
}

enum Status {
  YES
  MAYBE
  NO
  PENDING
}

enum Role {
  ORGANIZER
  MODERATOR
  ATTENDEE
}

model Invite {
  id            String     @id @default(cuid())
  event         Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId       String
  createdBy     Membership @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById   String
  createdAt     DateTime   @default(now())
  expiresAt     DateTime?  @default(now())
  usesRemaining Int?
  maxUses       Int?
  name          String?
}

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  person    Person           @relation("PersonNotifications", fields: [personId], references: [id], onDelete: Cascade)
  personId  String
  author    Person?          @relation("AuthorNotifications", fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String?
  type      NotificationType
  event     Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String?
  post      Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String?
  read      Boolean          @default(false)
  datetime  DateTime?
  rsvp      Status?
}

enum NotificationType {
  EVENT_EDITED // When the details of an event that the receiving user is a member of is edited
  NEW_POST // When a new post is created in an event that the receiving user is a member of
  NEW_REPLY // When a new reply is created in a post that the receiving user has interacted with
  DATE_CHOSEN // When the organizer of an event that the receiving user is a member of chooses a date
  DATE_CHANGED // When the organizer of an event that the receiving user is a member of changes the chosen date to a new single date
  DATE_RESET // When the organizer of an event that the receiving user is a member of starts a new poll for the date
  USER_JOINED // When another user joins an event that the receiving user owns or moderates
  USER_LEFT // When another user leaves an event that the receiving user owns or moderates
  USER_PROMOTED // When the receiving user is promoted to moderator of an event
  USER_DEMOTED // When the receiving user is demoted from moderator of an event
  USER_RSVP // When another user RSVPs to an event that the receiving user owns or moderates
}

enum NotificationMethodType {
  EMAIL
  PUSH
  WEBHOOK
}

enum WebhookFormat {
  DISCORD
  SLACK
  TEAMS
  GENERIC
  CUSTOM
}

// Updated model to reference PersonSettings instead of Person
model NotificationMethod {
  id         String                 @id @default(cuid())
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  settings   PersonSettings         @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  settingsId String
  type       NotificationMethodType
  enabled    Boolean                @default(true)
  name       String? // Name of the method, e.g., "Work Email", "Personal Webhook"
  value      String // Email address, webhook URL, etc.

  // Webhook-specific configuration (JSON fields for flexibility)
  webhookHeaders Json? // Custom headers as JSON object
  customTemplate String? // Custom JSON template with {{variable}} placeholders (only used when webhookFormat = CUSTOM)
  webhookFormat  WebhookFormat? // Preset format: discord, slack, teams, generic, custom

  notifications NotificationSetting[]
}

model NotificationSetting {
  id                 String             @id @default(cuid())
  notificationType   NotificationType
  notificationMethod NotificationMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  methodId           String
  enabled            Boolean            @default(true)

  @@unique([notificationType, methodId])
}
