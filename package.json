{
  "name": "groupi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev --filter=@groupi/web --filter=@groupi/convex --filter=@groupi/shared",
    "dev:web": "turbo dev --filter=@groupi/web",
    "dev:convex": "turbo dev --filter=@groupi/convex",
    "dev:shared": "turbo dev --filter=@groupi/shared",
    "dev:mobile": "cd packages/mobile && pnpm dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:mobile\" --names \"web,mobile\" --prefix-colors \"blue,green\"",
    "build": "turbo build --filter=@groupi/web --filter=@groupi/shared",
    "build:web": "turbo build --filter=@groupi/web",
    "build:convex": "turbo build --filter=@groupi/convex",
    "build:shared": "turbo build --filter=@groupi/shared",
    "build:mobile": "cd packages/mobile && pnpm build:android",
    "start": "turbo start --filter=@groupi/web",
    "preview": "concurrently \"npx convex dev\" \"pnpm build:web && pnpm start\" --names \"convex,next\" --prefix-colors \"yellow,cyan\"",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "test:watch": "turbo test:watch",
    "test:web": "turbo test:run --filter=@groupi/web",
    "test:convex": "turbo test:run --filter=@groupi/convex",
    "test:shared": "turbo test:run --filter=@groupi/shared",
    "test:mobile": "turbo test:run --filter=@groupi/mobile",
    "test:coverage": "turbo test:coverage",
    "test:coverage:web": "turbo test:coverage --filter=@groupi/web",
    "test:coverage:mobile": "turbo test:coverage --filter=@groupi/mobile",
    "test:coverage:shared": "turbo test:coverage --filter=@groupi/shared",
    "e2e": "pnpm --filter @groupi/web e2e",
    "e2e:ui": "pnpm --filter @groupi/web e2e:ui",
    "clean": "turbo clean && rm -rf node_modules && pnpm install",
    "clean:deps": "find . -name node_modules -type d -exec rm -rf {} + && pnpm install",
    "check": "pnpm lint && pnpm type-check && pnpm format:check",
    "lint:tokens": "pnpm --filter @groupi/web lint:tokens",
    "convex:dev": "pnpx convex dev",
    "convex:deploy": "pnpx convex deploy",
    "generate": "pnpx convex codegen",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "commit": "cz",
    "release": "changeset version && git add -A && git commit -m 'chore(release): version packages'"
  },
  "dependencies": {
    "@convex-dev/presence": "^0.3.0",
    "convex": "^1.31.4",
    "next": "^16.1.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@next/eslint-plugin-next": "^16.0.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "next-devtools-mcp": "^0.2.3",
    "prettier": "^3.6.2",
    "sharp": "^0.34.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
