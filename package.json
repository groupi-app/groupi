{
  "name": "groupi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- npx concurrently \"npm run dev:next | pino-pretty\" \"npm run dev:prisma\" \"npm run dev:db\" \"npm run dev:ngrok\"",
    "dev:next": "next dev --turbopack",
    "dev:prisma": "prisma studio",
    "dev:db": "docker compose up -d",
    "dev:ngrok": "./node_modules/.bin/ngrok http --authtoken=$NGROK_AUTHTOKEN --url=$NGROK_DOMAIN 3000",
    "next:stop": "npx kill-port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:migrate-deploy": "dotenv -e .env.local -- npx prisma migrate deploy",
    "postinstall": "dotenv -e .env.local -- prisma generate",
    "migrate": "dotenv -e .env.local -- prisma migrate dev",
    "generate": "dotenv -e .env.local -- prisma generate",
    "seed-users": "dotenv -e .env.local -- npx tsx scripts/seed-users.ts",
    "cypress:open": "cypress open",
    "e2e": "dotenv -e .env.local -- npx concurrently --success last \"npm run dev:db && npx wait-on http://localhost:5432\" \"npm run prisma:migrate-deploy && npm run dev:next && npx wait-on http://localhost:3000\" \"npx wait-on http://localhost:3000 && CYPRESS_DATABASE_URL=$DATABASE_URL npx cypress open\"",
    "e2e:headless": "dotenv -e .env.local ./scripts/e2e-full.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/backend": "^1.32.2",
    "@clerk/clerk-react": "^5.25.5",
    "@clerk/themes": "^1.7.9",
    "@hookform/resolvers": "^3.3.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@t3-oss/env-nextjs": "^0.9.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@tanstack/react-query": "^5.71.1",
    "@tiptap/extension-character-count": "^2.1.12",
    "@tiptap/extension-heading": "^2.1.12",
    "@tiptap/extension-placeholder": "^2.1.12",
    "@tiptap/extension-underline": "^2.1.12",
    "@tiptap/pm": "^2.1.12",
    "@tiptap/react": "^2.11.7",
    "@tiptap/starter-kit": "^2.1.12",
    "@types/node": "20.2.4",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vercel/analytics": "^1.0.1",
    "@vercel/speed-insights": "^1.0.10",
    "class-variance-authority": "^0.6.0",
    "clsx": "^1.2.1",
