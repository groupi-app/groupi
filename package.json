{
  "name": "groupi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm concurrently \"turbo dev --filter=@groupi/web | pino-pretty\" \"pnpm dev:prisma\" \"pnpm dev:db\"",
    "dev:prisma": "prisma studio --port 5555 --browser none",
    "dev:db": "supabase start",
    "dev:db:stop": "supabase stop",
    "next:stop": "pnpm kill-port 3000",
    "build": "turbo build",
    "start": "turbo start",
    "preview": "pnpm build && pnpm start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "prisma:migrate-deploy": "pnpm prisma migrate deploy",
    "db:setup": "./scripts/setup-db.sh",
    "db:reset": "./scripts/setup-db.sh",
    "postinstall": "prisma generate",
    "migrate": "pnpm prisma migrate dev",
    "generate": "prisma generate",
    "seed-users": "pnpm tsx scripts/seed-users.ts",
    "cypress:open": "cypress open",
    "e2e": "pnpm concurrently --success last \"pnpm dev:db && pnpm wait-on tcp:localhost:54322\" \"pnpm prisma:migrate-deploy && turbo dev --filter=@groupi/web && pnpm wait-on http://localhost:3000\" \"pnpm wait-on http://localhost:3000 && CYPRESS_DATABASE_URL=$DATABASE_URL pnpm cypress open\"",
    "e2e:headless": "./scripts/e2e-full.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "import-in-the-middle": "^2.0.0",
    "require-in-the-middle": "^8.0.1",
    "wait-on": "^9.0.1"
  },
  "devDependencies": {
    "@clerk/backend": "^2.19.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@next/eslint-plugin-next": "^16.0.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "cypress": "^15.5.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "next-devtools-mcp": "^0.2.3",
    "pino": "^10.1.0",
    "pino-abstract-transport": "^3.0.0",
    "pino-loki": "^2.6.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "start-server-and-test": "^2.1.2",
    "supabase": "^2.54.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "zod-prisma-types": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "require-in-the-middle": "8.0.1",
      "import-in-the-middle": "2.0.0",
      "effect": "^3.19.3"
    }
  },
  "overrides": {
    "@radix-ui/react-dismissable-layer": "^1.0.5",
    "@radix-ui/react-focus-scope": "^1.0.4",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "next-devtools-mcp>zod": "$zod",
    "require-in-the-middle": "8.0.1",
    "import-in-the-middle": "2.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
