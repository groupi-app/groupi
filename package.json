{
  "name": "groupi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm concurrently \"turbo dev --filter=@groupi/web | pino-pretty\" \"pnpm dev:prisma\" \"pnpm dev:db\"",
    "dev:prisma": "prisma studio --port 5555 --browser none",
    "dev:db": "supabase start",
    "dev:db:stop": "supabase stop",
    "next:stop": "pnpm kill-port 3000",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "prisma:migrate-deploy": "pnpm prisma migrate deploy",
    "postinstall": "prisma generate",
    "migrate": "pnpm prisma migrate dev",
    "generate": "pnpm prisma generate",
    "seed-users": "pnpm tsx scripts/seed-users.ts",
    "cypress:open": "cypress open",
    "e2e": "pnpm concurrently --success last \"pnpm dev:db && pnpm wait-on tcp:localhost:54322\" \"pnpm prisma:migrate-deploy && turbo dev --filter=@groupi/web && pnpm wait-on http://localhost:3000\" \"pnpm wait-on http://localhost:3000 && CYPRESS_DATABASE_URL=$DATABASE_URL pnpm cypress open\"",
    "e2e:headless": "./scripts/e2e-full.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^5.21.1",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^8.0.0",
    "import-in-the-middle": "^1.14.4",
    "require-in-the-middle": "^8.0.0",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@clerk/backend": "^1.34.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.27.0",
    "@next/eslint-plugin-next": "^15.3.4",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "cypress": "^13.14.2",
    "dotenv": "^16.5.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "prisma": "^5.21.1",
    "start-server-and-test": "^2.0.11",
    "supabase": "^2.33.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "zod-prisma-types": "^3.2.4"
  },
  "overrides": {
    "@radix-ui/react-dismissable-layer": "^1.0.5",
    "@radix-ui/react-focus-scope": "^1.0.4",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
